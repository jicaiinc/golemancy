{
  "name": "golemancy",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @golemancy/desktop test:e2e",
    "test:e2e:ai": "pnpm --filter @golemancy/desktop test:e2e:ai",
    "test:live": "pnpm --filter @golemancy/server test:live",
    "test:build": "node --test scripts/preflight-check.test.mjs scripts/bundle-server.test.mjs",
    "pack": "turbo build && pnpm --filter @golemancy/desktop run pack",
    "dist": "turbo build && pnpm --filter @golemancy/desktop run dist"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "@tailwindcss/oxide",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "turbo": "^2.8.0",
    "typescript": "^5.8.0"
  }
}
