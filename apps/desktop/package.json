{
  "name": "@solocraft/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test:e2e": "electron-vite build --mode test && npx playwright test --config=e2e/playwright.config.ts --project=smoke --project=server",
    "test:e2e:ai": "electron-vite build --mode test && npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:smoke": "electron-vite build --mode test && npx playwright test --config=e2e/playwright.config.ts --project=smoke",
    "test:e2e:only": "npx playwright test --config=e2e/playwright.config.ts"
  },
  "dependencies": {
    "@solocraft/shared": "workspace:*",
    "@solocraft/ui": "workspace:*",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^40.0.0",
    "electron-vite": "^5.0.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
